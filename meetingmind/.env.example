# Anthropic (Claude)
ANTHROPIC_API_KEY=          # console.anthropic.com → API Keys

# Butterbase
BUTTERBASE_API_KEY=         # butterbase.ai/dashboard → API Keys
BUTTERBASE_APP_ID=          # butterbase.ai/dashboard → your app's ID
BUTTERBASE_API_URL=         # butterbase.ai/dashboard → API URL (e.g. https://api.butterbase.ai/v1)

# AgentField
AGENTFIELD_CONTROL_PLANE_URL=http://localhost:8080   # local; change to Zeabur URL in prod

# EverMind / EverOS
EVERMIND_API_KEY=           # evermind.ai → dashboard
EVERMIND_API_URL=https://everos.evermind.ai

# Nosana GPU (deploy ml_server/ there to get this URL)
NOSANA_GPU_ENDPOINT=        # nosana.io → your deployed job endpoint

# Google Cloud (one project covers all three)
GOOGLE_CLIENT_ID=           # console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_SECRET=       # same place as above
GOOGLE_SERVICE_ACCOUNT_KEY= # console.cloud.google.com → IAM → Service Accounts → create key (JSON) → paste entire JSON here

# Deepgram ASR
DEEPGRAM_API_KEY=           # console.deepgram.com → API Keys

# SendGrid (MOM email)
SENDGRID_API_KEY=           # app.sendgrid.com → Settings → API Keys
MOM_FROM_EMAIL=             # a verified sender in your SendGrid account

# HuggingFace (needed for pyannote-audio diarization model)
HUGGINGFACE_TOKEN=          # huggingface.co/settings/tokens → New token (read access is enough)

# Dashboard
DEFAULT_ORG_ID=             # the UUID of your org row in Butterbase (created when you apply the schema)
